			"required": false,
			"allowedTypes": [
				"images"
			]
		},
		"year": {
			"type": "integer"
		},
		"startDate": {
			"type": "date"
		},
		"endDate": {
			"type": "date"
		},
		"clientName": {
			"type": "string"
		},
		"imageGallery": {
			"type": "media",
			"multiple": true,
			"required": false,
			"allowedTypes": [
				"images"
			]
		},
		"imageGallerySecond": {
			"type": "media",
			"multiple": true,
			"required": false,
			"allowedTypes": [
				"images"
			]
		},
		"content": {
			"type": "blocks"
		},
		"scopes": {
			"type": "relation",
			"relation": "manyToMany",
			"target": "api::scope.scope"
		},
		"industries": {
			"type": "relation",
			"relation": "manyToMany",
			"target": "api::industry.industry"
		},
		"locations": {
			"type": "relation",
			"relation": "manyToMany",
			"target": "api::location.location"
